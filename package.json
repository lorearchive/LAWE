    "@floating-ui/dom": "^1.7.6",
    "astro": "^6.0.4",
    "astro-sveltia-cms": "^0.1.0",
    "svelte": "^5.38.8",
    "typescript": "^5.9.2",
    "wrangler": "^4.73.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5"
  }
