---

const links = [
  { label: "About", href: "/about" },
  { label: "Donate", href: "/Donate" },
  { label: "Resource", href: "/resource" },
];
---

<header class="navbar-wrapper">
  <nav class="navbar">
    <!-- Logo -->
    <a href="/" class="logo a-no-style" aria-label="Home">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <!-- Planet body -->
        <circle cx="12" cy="12" r="4.5" />
        <!-- Ring -->
        <ellipse cx="12" cy="12" rx="10" ry="4" />
      </svg>
    </a>

    <!-- Nav links -->
    <ul class="nav-links" role="list">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="nav-link">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Email CTA -->
    <a href={"/login"} class="email-badge">
      Log In
    </a>
  </nav>
</header>

<style>
  :root {
    --nav-bg: #1c1c1e;
    --nav-text: #f0f0f0;
    --nav-link-hover: #ffffff;
    --badge-bg: #f5f5f5;
    --badge-text: #1c1c1e;
    --shadow: 0 8px 32px rgba(0, 0, 0, 0.22), 0 2px 8px rgba(0, 0, 0, 0.12);
    --font: "DM Sans", "Helvetica Neue", sans-serif;
    --radius-pill: 999px;
  }



  .navbar-wrapper {
    z-index: 100000;
    position: fixed;
    display: flex;
    justify-content: flex-start;
    padding: 1rem 1rem 1.5rem 1rem;
    font-family: var(--font);
    left: 0;
  }

  .navbar {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--nav-bg);
    border-radius: var(--radius-pill);
    padding: 0.45rem 0.45rem 0.45rem 0.45rem;
    box-shadow: var(--shadow);
    max-width: 680px;
    width: 100%;
  }

  /* Logo button */
  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    min-width: 42px;
    border-radius: 50%;
    background: #f5f5f5;
    color: var(--nav-bg);
    text-decoration: none;
    transition: transform 0.2s ease, background 0.2s ease;
    flex-shrink: 0;
  }

  .logo svg {
    width: 20px;
    height: 20px;
  }

  .logo:hover {
    transform: rotate(-12deg) scale(1.05);
    background: #ffffff;
  }

  /* Nav links */
  .nav-links {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0 0.5rem;
    gap: 0;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    display: block;
    padding: 0.5rem 1rem;
    text-decoration: none;
    font-size: 0.925rem;
    font-weight: 450;
    letter-spacing: 0.01em;
    border-radius: var(--radius-pill);
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
  }

  /* Active state */
  .nav-link[aria-current="page"] {
    color: #ffffff;
    font-weight: 500;
  }

  /* Email badge */
  .email-badge {
    display: flex;
    align-items: center;
    padding: 0.45rem 1.1rem;
    background: var(--badge-bg);
    color: var(--badge-text);
    border-radius: var(--radius-pill);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.15s ease, transform 0.15s ease;
    letter-spacing: 0.01em;
  }

  .email-badge:hover {
    background: #ffffff;
    transform: scale(1.02);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .nav-links {
      display: none;
    }

    .navbar {
      gap: 0.5rem;
      justify-content: space-between;
    }
  }
</style>