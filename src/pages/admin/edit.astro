---
import { auth } from "../../utils/auth"
import { getPage } from "../../utils/octo"

const session = await auth.api.getSession({ headers: Astro.request.headers })
if (!session) return Astro.redirect("/login")

const filePath = Astro.url.searchParams.get("file") || "test.txt"

const fileData = await getPage(Astro.request, filePath)

if (!fileData) {
    return new Response(`File not found at ${filePath}`, { status: 404 })
}
---

<html lang="en">
<head>
    <title>Lore Editor</title>
    <style>
        #editor { height: 80vh; border: 1px solid #333; }
        .cm-editor { height: 100%; }
    </style>
</head>
<body>
    <header>
        <h1>Editing: {filePath}</h1>
        <button id="save-btn" data-path={filePath} data-sha={fileData.sha}>Save to GitHub</button>
    </header>

<div id="editor"></div>
<script id="initial-data" type="application/json" set:html={JSON.stringify(fileData.content)}></script>
    <script>
        import { EditorState } from "@codemirror/state";
        import { EditorView, keymap, lineNumbers } from "@codemirror/view";
        import { defaultKeymap } from "@codemirror/commands";
        // import { yourCustomLoreLanguage } from "../../lib/lezer-parser";

        const container = document.getElementById("editor");
        const initialContent = container.getAttribute("data-initial-content");

        // Initialize Vanilla CodeMirror 6
        const state = EditorState.create({
            doc: initialContent,
            extensions: [
                lineNumbers(),
                keymap.of(defaultKeymap),
                // yourCustomLoreLanguage() <-- This is where your custom syntax goes!
            ]
        });

        const view = new EditorView({
            state,
            parent: container
        });

        // Handle Save
        document.getElementById("save-btn").addEventListener("click", async (e) => {
            const btn = e.target;
            const content = view.state.doc.toString();
            
            btn.innerText = "Saving...";
            
            const response = await fetch("/api/save", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    path: btn.dataset.path,
                    sha: btn.dataset.sha,
                    content: content
                })
            });

            if (response.ok) {
                btn.innerText = "Saved!";
                setTimeout(() => btn.innerText = "Save to GitHub", 2000);
            }
        });
    </script>
</body>
</html>