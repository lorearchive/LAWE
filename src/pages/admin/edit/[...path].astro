---
import { getPage, verifySession } from "../../../utils/octo";
import Editor from "../../../components/island/Editor.svelte";
 
const { path } = Astro.params;
 
if (!path) {
  return Astro.redirect("/");
}
 
let pageData: { content: string; sha: string } | null = null;
let error: string | null = null;
 
try {
    await verifySession(Astro.request);
    pageData = await getPage(path);

} catch (e: any) {

    if (e?.message === "Unauthorized") {
        return Astro.redirect("/login");
    }
    error = e?.message ?? "Unknown error";
}

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{path} — lore archive</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
      :root {
        --bg: #0f0f10;
        --surface: #18181b;
        --border: #2a2a2e;
        --text-primary: #e8e8e6;
        --text-secondary: #7a7a78;
        --text-muted: #3a3a38;
        --accent: #c8a96e;
        --danger: #c0504a;
        --success: #5a9e6f;
        --font-ui: "IBM Plex Sans", sans-serif;
        --font-code: "IBM Plex Mono", monospace;
      }
 
      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--text-primary);
        font-family: var(--font-ui);
        font-size: 14px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
 
      #app {
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
      }
 
      header {
        display: flex;
        align-items: center;
        height: 40px;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
        flex-shrink: 0;
        padding: 0 16px;
        user-select: none;
        gap: 0;
      }
 
      .header-wordmark {
        font-family: var(--font-code);
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.1em;
        color: var(--accent);
        text-transform: uppercase;
        margin-right: 16px;
      }
 
      .header-sep {
        width: 1px;
        height: 16px;
        background: var(--border);
        margin-right: 16px;
      }
 
      .header-path {
        font-family: var(--font-code);
        font-size: 12px;
        color: var(--text-secondary);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex: 1;
      }
 
      .header-path .seg { color: #4a4a48; }
      .header-path .filename { color: var(--text-primary); }
 
      .editor-wrap {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
 
      .error-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        gap: 12px;
        color: var(--text-secondary);
        font-family: var(--font-ui);
      }
 
      .error-state code {
        font-family: var(--font-code);
        font-size: 12px;
        color: var(--danger);
        background: rgba(192, 80, 74, 0.1);
        padding: 4px 10px;
        border-radius: 4px;
      }
    </style>
  </head>

  <body>
    <div id="app">
      <header>
        <span class="header-wordmark">Lore Archive Wiki Web Editor</span>
        <div class="header-sep"></div>
        <div class="header-path">
          {
            (() => {
              const parts = path.split("/");
              return parts.map((seg, i) =>
                i < parts.length - 1
                  ? <span class="seg">{seg}/</span>
                  : <span class="filename">{seg}</span>
              );
            })()
          }
        </div>
      </header>
 
      <div class="editor-wrap">
        {
          error ? (
            <div class="error-state">
              <p>could not load page</p>
              <code>{error}</code>
            </div>
          ) : (
            <Editor
              client:only="svelte"
              path={path}
              initialContent={pageData?.content ?? ""}
              sha={pageData?.sha ?? ""}
            />
          )
        }
      </div>
    </div>
  </body>
</html>